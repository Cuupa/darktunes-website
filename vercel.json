{
  "framework": "nextjs",
  "buildCommand": "next build",
  "devCommand": "next dev",
  "installCommand": "bash scripts/vercel-install.sh",
  "headers": [
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "functions": {
    "app/api/sync/route.ts": { "maxDuration": 300 },
    "app/api/sync-youtube/route.ts": { "maxDuration": 300 }
  },
  "crons": [
    {
      "path": "/api/sync-youtube",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/sync",
      "schedule": "0 3 * * *"
    }
  ]
}
