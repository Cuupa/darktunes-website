{
  "framework": "nextjs",
  "buildCommand": "next build",
  "devCommand": "next dev",
  "installCommand": "bash scripts/vercel-install.sh",
  "headers": [
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "functions": {
    "app/api/sync/query/route.ts": { "maxDuration": 300 },
    "app/api/sync/execute/route.ts": { "maxDuration": 300 },
    "app/api/sync-youtube/route.ts": { "maxDuration": 300 },
    "app/api/process-sync-queue/route.ts": { "maxDuration": 60 }
  }
}
