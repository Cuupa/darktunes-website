{
  "framework": "nextjs",
  "buildCommand": "next build",
  "devCommand": "next dev",
  "installCommand": "bash scripts/vercel-install.sh",
  "headers": [
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "functions": {
    "app/api/sync/queue/route.ts": { "maxDuration": 300 },
    "app/api/sync/execute/route.ts": { "maxDuration": 300 },
    "app/api/sync-youtube/route.ts": { "maxDuration": 300 },
    "app/api/health/alert/route.ts": { "maxDuration": 60 }
  },
  "crons": [
    { "path": "/api/sync/execute", "schedule": "*/5 * * * *" },
    { "path": "/api/health/alert", "schedule": "*/10 * * * *" },
    { "path": "/api/sync/queue", "schedule": "0 3 * * *" },
    { "path": "/api/sync-youtube", "schedule": "0 6 * * *" }
  ]
}
