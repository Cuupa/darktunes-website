# =============================================================================
# .env.example — darkTunes Music Group
# =============================================================================
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local or any file containing real secrets.
#
# Variable prefixes:
#   NEXT_PUBLIC_*   → exposed to the browser (Next.js build-time injection)
#   (no prefix)     → server-side only (Next.js Route Handlers / Edge Middleware)
#
# See DEPLOYMENT.md for a full description of each variable and where to
# obtain the values.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase  (client-side — required)
# https://supabase.com → Project Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# -----------------------------------------------------------------------------
# Supabase  (server-side — used in Next.js Route Handlers and Middleware only)
# https://supabase.com → Project Settings → API → service_role key (keep secret!)
# -----------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# -----------------------------------------------------------------------------
# Cloudflare R2  (server-side — used in Next.js Route Handlers only)
# https://dash.cloudflare.com → R2 → Manage R2 API Tokens
# -----------------------------------------------------------------------------
CLOUDFLARE_R2_ACCOUNT_ID=your-cloudflare-account-id-here
CLOUDFLARE_R2_ACCESS_KEY_ID=your-r2-access-key-id-here
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-r2-secret-access-key-here
CLOUDFLARE_R2_BUCKET_NAME=darktunes-assets
CLOUDFLARE_R2_PUBLIC_URL=https://cdn.your-domain.com

# -----------------------------------------------------------------------------
# API credentials encryption master key (server-side only — required)
# Encrypts external integration keys stored in Supabase api_credentials table.
# Generate with: openssl rand -hex 32
# NEVER store this in Supabase or commit it to git.
# External API keys (Spotify, Resend, etc.) are configured in Admin → API Keys.
# -----------------------------------------------------------------------------
API_CREDENTIALS_ENCRYPTION_KEY=your-64-char-hex-encryption-key-here

# -----------------------------------------------------------------------------
# Runtime / deployment (set automatically by Vercel — no manual action needed)
# -----------------------------------------------------------------------------
# VERCEL_ENV=production   # production | preview | development  (Vercel-injected)
# NODE_ENV=production     # production | development            (Node-injected)

# -----------------------------------------------------------------------------
# Email / contact inboxes (server-side only — not integration API keys)
# -----------------------------------------------------------------------------
CONTACT_EMAIL=info@darktunes.com
LABEL_NOTIFICATION_EMAIL=label@darktunes.com

# -----------------------------------------------------------------------------
# Public site URL (used to build confirmation links in emails)
# Must match the deployed Vercel URL (no trailing slash).
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://darktunes.com

# -----------------------------------------------------------------------------
# Cache revalidation webhook secret
# A random, high-entropy string used to authenticate Supabase Database Webhooks
# that call POST /api/revalidate to bust the Next.js ISR cache.
# Generate with: openssl rand -hex 32
# Configure as a Supabase Webhook custom header: Authorization: Bearer <value>
# -----------------------------------------------------------------------------
REVALIDATE_SECRET=your-revalidate-secret-here

# Optional shared secret for cron and external trigger calls.
# Accepted by /api/sync, /api/sync-youtube, and /api/sync-api.
# Also required by the trigger-sync Supabase Edge Function.
# If set, cron requests must send: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=your-cron-secret-here

# -----------------------------------------------------------------------------
# Legacy API keys (optional — one-time import via Admin → API Keys only)
# Add temporarily in Vercel, run Import from environment variables, then remove.
# -----------------------------------------------------------------------------
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# DISCOGS_TOKEN=
# SONGKICK_API_KEY=
# BANDSINTOWN_API_KEY=
# LASTFM_API_KEY=
# SOUNDCHARTS_API_KEY=
# YOUTUBE_API_KEY=
# YOUTUBE_CHANNEL_ID=
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=
# MAILERLITE_API_KEY=
# MAILERLITE_GROUP_ID=
# HEALTH_ALERT_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Supabase Edge Function secrets (newsletter-confirm only — not in Admin UI yet)
# Configure in Supabase Dashboard → Edge Functions → Secrets:
#   RESEND_API_KEY, RESEND_FROM_EMAIL, NEXT_PUBLIC_SITE_URL
# Next.js routes read Resend from Admin → API Keys (encrypted in api_credentials).
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Supabase Read Replica (optional — Supabase Pro plan required)
# When set, heavy analytics queries (portal/analytics, admin health, SOS CSV)
# are routed to the replica instead of the primary DB to reduce load.
# Configure via Supabase Dashboard → Database → Replicas.
# Falls back to the primary DB when not set (safe for dev environments).
# -----------------------------------------------------------------------------
SUPABASE_REPLICA_URL=
SUPABASE_REPLICA_ANON_KEY=

# -----------------------------------------------------------------------------
# Playwright E2E — optional authenticated tests (skipped automatically when unset)
# -----------------------------------------------------------------------------
PLAYWRIGHT_PORTAL_EMAIL=
PLAYWRIGHT_PORTAL_PASSWORD=
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=
E2E_JOURNALIST_EMAIL=
E2E_JOURNALIST_PASSWORD=